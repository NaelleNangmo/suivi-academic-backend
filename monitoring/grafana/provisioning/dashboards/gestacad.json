{
  "title": "GestAcad — Laravel Monitoring",
  "uid": "gestacad-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Requêtes HTTP totales",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(laravel_http_requests_total)", "legendFormat": "Total" }],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2, "type": "stat", "title": "Taux d'erreurs 5xx",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(rate(laravel_http_requests_total{status=~\"5..\"}[5m]))", "legendFormat": "5xx/s" }],
      "options": { "colorMode": "background", "thresholds": { "steps": [{"color":"green","value":0},{"color":"red","value":0.1}] } }
    },
    {
      "id": 3, "type": "stat", "title": "Latence médiane (p50)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "histogram_quantile(0.50, sum(rate(laravel_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" }],
      "options": { "unit": "s", "colorMode": "background" }
    },
    {
      "id": 4, "type": "stat", "title": "Latence p95",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(laravel_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }],
      "options": { "unit": "s", "colorMode": "background" }
    },
    {
      "id": 5, "type": "timeseries", "title": "Requêtes par statut HTTP",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (status) (rate(laravel_http_requests_total[1m]))", "legendFormat": "{{status}}" }]
    },
    {
      "id": 6, "type": "timeseries", "title": "Durée des requêtes (p50 / p95 / p99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(laravel_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(laravel_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(laravel_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 7, "type": "stat", "title": "Filières en base",
      "gridPos": { "x": 0, "y": 12, "w": 6, "h": 4 },
      "targets": [{ "expr": "laravel_db_filieres_total", "legendFormat": "Filières" }],
      "options": { "colorMode": "background" }
    },
    {
      "id": 8, "type": "stat", "title": "Personnel en base",
      "gridPos": { "x": 6, "y": 12, "w": 6, "h": 4 },
      "targets": [{ "expr": "laravel_db_personnels_total", "legendFormat": "Personnel" }],
      "options": { "colorMode": "background" }
    },
    {
      "id": 9, "type": "stat", "title": "EC en base",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 4 },
      "targets": [{ "expr": "laravel_db_ecs_total", "legendFormat": "EC" }],
      "options": { "colorMode": "background" }
    },
    {
      "id": 10, "type": "stat", "title": "Programmations en base",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 4 },
      "targets": [{ "expr": "laravel_db_programmations_total", "legendFormat": "Programmations" }],
      "options": { "colorMode": "background" }
    },
    {
      "id": 11, "type": "timeseries", "title": "Tentatives d'authentification",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (status) (rate(laravel_auth_attempts_total[5m]))", "legendFormat": "{{status}}" }]
    },
    {
      "id": 12, "type": "timeseries", "title": "CPU & Mémoire (node-exporter)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %" },
        { "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "RAM %" }
      ]
    }
  ]
}
